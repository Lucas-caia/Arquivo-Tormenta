{
  "name": "arquivo-tormenta-rpg",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host 0.0.0.0\" \"tsx watch server/server.ts\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist-server/server.js",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit && vite build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.7.0",
    "vite": "6.3.5",
    "typescript": "5.7.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "lucide-react": "0.468.0",
    "express": "4.19.2",
    "multer": "1.4.5-lts.1",
    "pdf-lib": "1.17.1"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/multer": "1.4.12",
    "@types/node": "22.10.2",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "concurrently": "9.1.0",
    "tsx": "4.19.2"
  }
}
